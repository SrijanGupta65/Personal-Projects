# Copy this file to ".env" and adjust if needed:  cp .env.example .env
#
# DATABASE_URL is the ONLY thing that decides which database the code talks to.
#
# Local Docker (development) -- matches docker-compose.yml:
DATABASE_URL=postgresql://nurseassist:nurseassist@localhost:5432/nurseassist
#
# AWS RDS (later) -- replace with your RDS endpoint and credentials:
# DATABASE_URL=postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>
